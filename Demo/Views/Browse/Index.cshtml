@model Demo.Models.ViewModels.Browse.BrowseIndexVm

@{
    ViewData["Title"] = "Browse Parts";
    var currentType = Model.Filter.PartType ?? Demo.Models.PartType.CPU;
    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
}

<style>
    :root {
        --bg-1: #0a0f1f;
        --bg-2: #11182d;
        --bg-3: #1a2340;
        --card-bg: rgba(20, 28, 48, 0.82);
        --card-bg-2: rgba(12, 18, 34, 0.88);
        --card-border: rgba(97, 218, 251, 0.18);
        --accent: #61dafb;
        --accent-2: #7c4dff;
        --accent-3: #00e5ff;
        --text-main: #f4f8ff;
        --text-soft: rgba(244, 248, 255, 0.72);
        --text-faded: rgba(244, 248, 255, 0.50);
        --shadow-blue: 0 0 30px rgba(97, 218, 251, 0.18);
        --shadow-purple: 0 0 36px rgba(124, 77, 255, 0.16);
    }

    body {
        background: radial-gradient(circle at 20% 20%, rgba(97, 218, 251, 0.08), transparent 24%), radial-gradient(circle at 80% 30%, rgba(124, 77, 255, 0.09), transparent 26%), radial-gradient(circle at 50% 80%, rgba(0, 229, 255, 0.07), transparent 24%), linear-gradient(135deg, var(--bg-1), var(--bg-2), var(--bg-3));
        color: var(--text-main);
        overflow-x: hidden;
    }

    .browse-shell {
        position: relative;
        isolation: isolate;
        overflow: hidden;
        min-height: 100vh;
        padding-bottom: 3rem;
    }

        .browse-shell::before {
            content: "";
            position: fixed;
            inset: 0;
            background: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
            background-size: 42px 42px;
            mask-image: radial-gradient(circle at center, black 30%, transparent 88%);
            z-index: -5;
            pointer-events: none;
            animation: gridShift 18s linear infinite;
        }

    .bg-orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(75px);
        opacity: .42;
        z-index: -4;
        pointer-events: none;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        animation-direction: alternate;
    }

    .orb-1 {
        width: 360px;
        height: 360px;
        top: 5%;
        left: -8%;
        background: rgba(97, 218, 251, 0.20);
        animation: floatOrb1 10s infinite;
    }

    .orb-2 {
        width: 420px;
        height: 420px;
        top: 30%;
        right: -10%;
        background: rgba(124, 77, 255, 0.18);
        animation: floatOrb2 13s infinite;
    }

    .orb-3 {
        width: 300px;
        height: 300px;
        bottom: 0;
        left: 32%;
        background: rgba(0, 229, 255, 0.14);
        animation: floatOrb3 11s infinite;
    }

    .particles {
        position: fixed;
        inset: 0;
        z-index: -3;
        pointer-events: none;
        overflow: hidden;
    }

    .particle {
        position: absolute;
        bottom: -20px;
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: rgba(97, 218, 251, 0.85);
        box-shadow: 0 0 10px rgba(97, 218, 251, 0.75);
        animation: rise linear infinite;
    }

        .particle:nth-child(1) {
            left: 4%;
            animation-duration: 12s;
            animation-delay: 0s;
        }

        .particle:nth-child(2) {
            left: 11%;
            animation-duration: 15s;
            animation-delay: 2s;
        }

        .particle:nth-child(3) {
            left: 18%;
            animation-duration: 18s;
            animation-delay: 4s;
        }

        .particle:nth-child(4) {
            left: 26%;
            animation-duration: 13s;
            animation-delay: 6s;
        }

        .particle:nth-child(5) {
            left: 34%;
            animation-duration: 16s;
            animation-delay: 1s;
        }

        .particle:nth-child(6) {
            left: 41%;
            animation-duration: 14s;
            animation-delay: 5s;
        }

        .particle:nth-child(7) {
            left: 49%;
            animation-duration: 17s;
            animation-delay: 3s;
        }

        .particle:nth-child(8) {
            left: 57%;
            animation-duration: 16s;
            animation-delay: 7s;
        }

        .particle:nth-child(9) {
            left: 65%;
            animation-duration: 19s;
            animation-delay: 2.5s;
        }

        .particle:nth-child(10) {
            left: 73%;
            animation-duration: 12s;
            animation-delay: 4.5s;
        }

        .particle:nth-child(11) {
            left: 81%;
            animation-duration: 18s;
            animation-delay: 6.5s;
        }

        .particle:nth-child(12) {
            left: 89%;
            animation-duration: 15s;
            animation-delay: 8s;
        }

        .particle:nth-child(13) {
            left: 95%;
            animation-duration: 14s;
            animation-delay: 5s;
        }

    .hero-panel {
        position: relative;
        padding: 2.25rem 2rem;
        border-radius: 30px;
        background: linear-gradient(145deg, rgba(19, 28, 48, 0.92), rgba(14, 20, 36, 0.88));
        border: 1px solid rgba(97, 218, 251, 0.16);
        box-shadow: 0 18px 55px rgba(0,0,0,0.28), 0 0 35px rgba(97, 218, 251, 0.08);
        overflow: hidden;
        margin-top: 1.25rem;
    }

        .hero-panel::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top left, rgba(97, 218, 251, 0.12), transparent 28%), radial-gradient(circle at bottom right, rgba(124, 77, 255, 0.12), transparent 30%);
            pointer-events: none;
        }

    .browse-badge {
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        padding: .55rem 1rem;
        border-radius: 999px;
        border: 1px solid rgba(97, 218, 251, 0.22);
        background: rgba(97, 218, 251, 0.08);
        color: var(--accent);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .08em;
        font-size: .8rem;
        box-shadow: var(--shadow-blue);
    }

    .browse-title {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 900;
        line-height: .98;
        margin: 1rem 0 .8rem;
        text-transform: uppercase;
        letter-spacing: -.03em;
    }

    .title-glow {
        color: var(--accent);
        text-shadow: 0 0 12px rgba(97, 218, 251, 0.42), 0 0 28px rgba(97, 218, 251, 0.18);
    }

    .browse-subtitle {
        color: var(--text-soft);
        font-size: 1.03rem;
        line-height: 1.85;
        max-width: 820px;
        margin: 0;
    }

    .quick-stats {
        margin-top: 1.5rem;
    }

    .quick-stat {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 22px;
        padding: 1rem 1.1rem;
        height: 100%;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.01);
    }

        .quick-stat .value {
            display: block;
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--accent);
            line-height: 1;
            margin-bottom: .35rem;
        }

        .quick-stat .label {
            color: var(--text-faded);
            font-size: .92rem;
            font-weight: 600;
        }

    .glass-panel {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 28px;
        box-shadow: 0 16px 50px rgba(0,0,0,0.20), inset 0 0 0 1px rgba(255,255,255,0.02);
        backdrop-filter: blur(16px);
    }

    .section-card {
        overflow: hidden;
    }

    .section-card-header {
        padding: 1.2rem 1.35rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
    }

        .section-card-header h5,
        .section-card-header h4 {
            margin: 0;
            color: var(--accent);
            font-weight: 800;
        }

        .section-card-header p {
            margin: .35rem 0 0;
            color: var(--text-faded);
            font-size: .9rem;
        }

    .section-card-body {
        padding: 1.2rem;
    }

    .admin-btn,
    .browse-btn-main,
    .browse-btn-outline {
        border-radius: 999px;
        font-weight: 800;
        transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease, background .22s ease;
    }

    .admin-btn,
    .browse-btn-main {
        background: linear-gradient(90deg, var(--accent), #8fe9ff);
        color: #07121d !important;
        border: none;
        box-shadow: 0 0 24px rgba(97, 218, 251, 0.22);
        padding: .85rem 1.25rem;
    }

        .admin-btn:hover,
        .browse-btn-main:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 0 34px rgba(97, 218, 251, 0.34);
            color: #07121d !important;
        }

    .browse-btn-outline {
        background: rgba(255,255,255,0.03);
        color: white !important;
        border: 1px solid rgba(97, 218, 251, 0.25);
        padding: .72rem 1.1rem;
    }

        .browse-btn-outline:hover {
            transform: translateY(-3px);
            border-color: rgba(97, 218, 251, 0.52);
            box-shadow: 0 0 26px rgba(97, 218, 251, 0.12);
        }

    .type-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: .8rem;
        margin-top: 1.8rem;
        margin-bottom: 1.8rem;
    }

    .type-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .55rem;
        padding: .8rem 1.15rem;
        border-radius: 999px;
        text-decoration: none;
        color: var(--text-main);
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        font-weight: 700;
        transition: all .22s ease;
    }

        .type-pill:hover {
            transform: translateY(-3px);
            color: white;
            border-color: rgba(97, 218, 251, 0.32);
            box-shadow: 0 0 24px rgba(97, 218, 251, 0.10);
        }

        .type-pill.active {
            background: linear-gradient(135deg, rgba(97, 218, 251, 0.16), rgba(124, 77, 255, 0.16));
            color: white;
            border-color: rgba(97, 218, 251, 0.32);
            box-shadow: 0 0 24px rgba(97, 218, 251, 0.12);
        }

    .results-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .8rem;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .results-count {
        color: var(--text-faded);
        font-size: .95rem;
    }

        .results-count strong {
            color: white;
        }

    .category-chip {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .65rem 1rem;
        border-radius: 999px;
        background: rgba(97, 218, 251, 0.08);
        border: 1px solid rgba(97, 218, 251, 0.18);
        color: var(--accent);
        font-weight: 700;
        font-size: .9rem;
    }

    .filter-panel {
        position: sticky;
        top: 1.25rem;
    }

        .filter-panel .section-card-body {
            padding: 1.25rem;
        }

        .filter-panel label,
        .filter-panel .form-label,
        .filter-panel .form-check-label,
        .filter-panel .control-label {
            color: rgba(244, 248, 255, 0.84) !important;
            font-weight: 600;
        }

        .filter-panel input,
        .filter-panel select,
        .filter-panel textarea,
        .filter-panel .form-control,
        .filter-panel .form-select {
            background: rgba(9, 15, 30, 0.95) !important;
            border: 1px solid rgba(255,255,255,0.10) !important;
            color: white !important;
            border-radius: 16px !important;
            box-shadow: none !important;
        }

            .filter-panel input:focus,
            .filter-panel select:focus,
            .filter-panel textarea:focus,
            .filter-panel .form-control:focus,
            .filter-panel .form-select:focus {
                border-color: rgba(97, 218, 251, 0.55) !important;
                box-shadow: 0 0 0 .18rem rgba(97, 218, 251, 0.14) !important;
            }

            .filter-panel input::placeholder {
                color: rgba(255,255,255,0.35);
            }

    .part-card {
        position: relative;
        height: 100%;
        overflow: hidden;
        transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }

        .part-card:hover {
            transform: translateY(-8px);
            border-color: rgba(97, 218, 251, 0.34);
            box-shadow: 0 18px 55px rgba(0,0,0,0.28), 0 0 30px rgba(97, 218, 251, 0.12);
        }

        .part-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, rgba(97, 218, 251, 0.08), transparent 26%), radial-gradient(circle at bottom left, rgba(124, 77, 255, 0.07), transparent 28%);
            opacity: 0;
            transition: opacity .25s ease;
            pointer-events: none;
        }

        .part-card:hover::before {
            opacity: 1;
        }

    .part-image-wrap {
        position: relative;
        height: 210px;
        background: linear-gradient(145deg, rgba(8, 13, 24, 0.96), rgba(15, 22, 40, 0.92));
        border-bottom: 1px solid rgba(255,255,255,0.08);
        overflow: hidden;
    }

        .part-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .35s ease;
        }

    .part-card:hover .part-image-wrap img {
        transform: scale(1.06);
    }

    .part-image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(5, 9, 18, 0.68), rgba(5, 9, 18, 0.05));
        pointer-events: none;
    }

    .part-type-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 2;
        padding: .48rem .8rem;
        border-radius: 999px;
        background: rgba(97, 218, 251, 0.12);
        border: 1px solid rgba(97, 218, 251, 0.22);
        color: var(--accent);
        font-weight: 800;
        font-size: .76rem;
        letter-spacing: .03em;
        backdrop-filter: blur(10px);
    }

    .image-fallback {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        color: var(--text-faded);
        gap: .6rem;
    }

        .image-fallback i {
            font-size: 2rem;
            color: rgba(97, 218, 251, 0.7);
        }

    .part-card-body {
        padding: 1.2rem;
        position: relative;
        z-index: 1;
    }

    .part-title {
        color: #f7fbff;
        font-size: 1.08rem;
        font-weight: 800;
        margin-bottom: .25rem;
        line-height: 1.35;
    }

    .part-brand {
        color: var(--text-faded);
        font-size: .92rem;
        margin-bottom: .9rem;
        font-weight: 600;
    }

    .short-spec-box {
        min-height: 54px;
        padding: .8rem .9rem;
        border-radius: 16px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.05);
        color: var(--text-soft);
        font-size: .92rem;
        line-height: 1.55;
    }

    .price-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 1rem;
        margin-bottom: 1rem;
        gap: .8rem;
    }

    .price-value {
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--accent);
        text-shadow: 0 0 10px rgba(97, 218, 251, 0.18);
    }

    .price-note {
        color: var(--text-faded);
        font-size: .82rem;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .65rem;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
    }

        .empty-state i {
            font-size: 2.6rem;
            color: rgba(97, 218, 251, 0.75);
            margin-bottom: 1rem;
        }

        .empty-state h4 {
            font-weight: 800;
            margin-bottom: .7rem;
        }

        .empty-state p {
            color: var(--text-soft);
            max-width: 520px;
            margin: 0 auto;
            line-height: 1.8;
        }

    .reveal {
        opacity: 0;
        transform: translateY(34px);
        transition: opacity .8s ease, transform .8s ease;
    }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

    @@keyframes gridShift {
        0% {
            transform: translateY(0);
        }

        100% {
            transform: translateY(42px);
        }
    }

    @@keyframes floatOrb1 {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(75px, 48px) scale(1.1);
        }
    }

    @@keyframes floatOrb2 {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(-70px, 55px) scale(1.08);
        }
    }

    @@keyframes floatOrb3 {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(50px, -62px) scale(1.1);
        }
    }

    @@keyframes rise {
        0% {
            transform: translateY(0) translateX(0);
            opacity: 0;
        }

        10% {
            opacity: .95;
        }

        70% {
            opacity: .65;
        }

        100% {
            transform: translateY(-110vh) translateX(24px);
            opacity: 0;
        }
    }

    @@media (max-width: 991.98px) {
        .filter-panel {
            position: static;
        }

        .hero-panel {
            padding: 1.7rem 1.3rem;
        }
    }

    @@media (max-width: 767.98px) {
        .browse-title {
            font-size: 2rem;
        }

        .type-tabs {
            gap: .6rem;
        }

        .type-pill {
            width: 100%;
            justify-content: center;
        }

        .results-meta {
            align-items: flex-start;
            flex-direction: column;
        }

        .card-actions .browse-btn-outline,
        .card-actions .browse-btn-main {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="browse-shell">

    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>
    <div class="bg-orb orb-3"></div>

    <div class="particles">
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
    </div>

    <div class="container py-4">

        <div class="hero-panel reveal">
            <div class="row g-4 align-items-center">
                <div class="col-lg-8">
                    <div class="browse-badge">
                        <i class="fa-solid fa-bolt"></i>
                        Hardware Browser
                    </div>

                    <h1 class="browse-title">
                        Browse <span class="title-glow">parts</span> without the clutter.
                    </h1>

                    <p class="browse-subtitle">
                        Filter fast, scan specs clearly, and jump between categories without digging through a messy page.
                        This section is built to make PC parts feel clean, sharp, and easy to compare.
                    </p>
                </div>

                <div class="col-lg-4">
                    <div class="row g-3 quick-stats">
                        <div class="col-6">
                            <div class="quick-stat">
                                <span class="value">@Model.Items.Count</span>
                                <span class="label">Visible items</span>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="quick-stat">
                                <span class="value">@currentType</span>
                                <span class="label">Current type</span>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="quick-stat">
                                <span class="value">Live Filter</span>
                                <span class="label">Price, brand, and capability focused browsing</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">
                <div class="category-chip">
                    <i class="fa-solid fa-layer-group"></i>
                    Active Category: @currentType
                </div>

                @if (isAdmin)
                {
                    <a class="admin-btn text-decoration-none"
                       asp-action="Create"
                       asp-route-partType="@currentType">
                        <i class="fa-solid fa-plus me-2"></i>
                        Add New Item
                    </a>
                }
            </div>
        </div>

        <div class="type-tabs reveal">
            @foreach (Demo.Models.PartType t in Enum.GetValues(typeof(Demo.Models.PartType)))
            {
                var isActive = currentType == t;
                <a class="type-pill @(isActive ? "active" : "")"
                   asp-action="Index"
                   asp-route-partType="@t">
                    <i class="fa-solid fa-microchip"></i>
                    @t
                </a>
            }
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-3">
                <div class="glass-panel section-card filter-panel reveal">
                    <div class="section-card-header">
                        <h5><i class="fa-solid fa-sliders me-2"></i>Filters</h5>
                        <p>Tune results by category, price, brand, and hardware capability.</p>
                    </div>
                    <div class="section-card-body">
                        <partial name="_Filters" model="Model" />
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-9">
                <div class="results-meta reveal">
                    <div class="results-count">
                        Showing <strong>@Model.Items.Count</strong> item(s) in <strong>@currentType</strong>
                    </div>

                    <div class="category-chip">
                        <i class="fa-solid fa-eye"></i>
                        Clean comparison view
                    </div>
                </div>

                @if (Model.Items.Count == 0)
                {
                    <div class="glass-panel section-card reveal">
                        <div class="empty-state">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <h4>No items found</h4>
                            <p>
                                Your current filters did not match anything in this category.
                                Try widening the price range, changing brand, or removing one of the capability filters.
                            </p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var item in Model.Items)
                        {
                            <div class="col-12 col-md-6 col-xl-4">
                                <div class="glass-panel part-card reveal">

                                    <div class="part-image-wrap">
                                        <div class="part-type-badge">@item.PartType</div>
                                        <div class="part-image-overlay"></div>

                                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl"
                                                 alt="@item.Name" />
                                        }
                                        else
                                        {
                                            <div class="image-fallback">
                                                <i class="fa-solid fa-image"></i>
                                                <span class="small">No image available</span>
                                            </div>
                                        }
                                    </div>

                                    <div class="part-card-body">
                                        <div class="part-title">@item.Name</div>
                                        <div class="part-brand">@item.Brand</div>

                                        @if (!string.IsNullOrWhiteSpace(item.ShortSpec))
                                        {
                                            <div class="short-spec-box">
                                                @item.ShortSpec
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="short-spec-box">
                                                No short specification available for this item yet.
                                            </div>
                                        }

                                        <div class="price-row">
                                            <div>
                                                <div class="price-note">Current Price</div>
                                                <div class="price-value">$@item.Price</div>
                                            </div>

                                            <div class="category-chip">
                                                <i class="fa-solid fa-circle-info"></i>
                                                Specs Ready
                                            </div>
                                        </div>

                                        <div class="card-actions">
                                            <a class="browse-btn-outline text-decoration-none"
                                               asp-action="Details"
                                               asp-route-partType="@item.PartType"
                                               asp-route-id="@item.Id">
                                                <i class="fa-solid fa-arrow-up-right-from-square me-2"></i>
                                                Details
                                            </a>

                                            @if (isAdmin)
                                            {
                                                <a class="browse-btn-main text-decoration-none"
                                                   asp-action="Edit"
                                                   asp-route-partType="@item.PartType"
                                                   asp-route-id="@item.Id">
                                                    <i class="fa-solid fa-pen-to-square me-2"></i>
                                                    Edit
                                                </a>
                                            }
                                        </div>
                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const revealItems = document.querySelectorAll('.reveal');

            const revealOnScroll = () => {
                revealItems.forEach((item, index) => {
                    const rect = item.getBoundingClientRect();
                    if (rect.top < window.innerHeight - 70) {
                        setTimeout(() => {
                            item.classList.add('active');
                        }, index * 45);
                    }
                });
            };

            revealOnScroll();
            window.addEventListener('scroll', revealOnScroll);

            const particles = document.querySelectorAll('.particle');
            particles.forEach(p => {
                const randomX = (Math.random() * 30 - 15).toFixed(2) + 'px';
                const randomScale = (0.7 + Math.random() * 1.2).toFixed(2);
                p.style.transform = `translateX(${randomX}) scale(${randomScale})`;
            });
        })();
    </script>
}