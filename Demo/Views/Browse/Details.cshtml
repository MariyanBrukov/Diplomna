@model Demo.Models.ViewModels.Browse.PartDetailsVm

@{
    ViewData["Title"] = $"{Model.PartType} Details";
    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
}

<style>
    .desc-card {
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.10);
        border-radius: 14px;
        padding: 14px 14px 12px 14px;
        position: relative;
    }

        .desc-card:before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            border-radius: 14px 0 0 14px;
            background: rgba(97,218,251,.75);
        }

    .desc-title {
        font-weight: 700;
        letter-spacing: .2px;
        margin-left: 8px;
        margin-bottom: 6px;
        color: rgba(255,255,255,.85);
    }

    .desc-text {
        margin-left: 8px;
        color: rgba(233,236,239,.80);
        line-height: 1.65;
        white-space: pre-line;
    }

    .meta-pill {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .35rem .6rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(255,255,255,.03);
        color: rgba(233,236,239,.75);
        font-size: .9rem;
    }
</style>

<div class="container py-3" style="color:#e9ecef;">
    <div class="mb-3 d-flex flex-wrap gap-2">
        <a asp-action="Index" asp-route-partType="@Model.PartType" class="btn btn-outline-info">
            ← Back
        </a>

        @if (isAdmin)
        {
            <a asp-action="Edit"
               asp-route-partType="@Model.PartType"
               asp-route-id="@Model.Id"
               class="btn btn-outline-secondary">
                Edit
            </a>

            <a asp-action="Delete"
               asp-route-partType="@Model.PartType"
               asp-route-id="@Model.Id"
               class="btn btn-outline-danger">
                Delete
            </a>
        }
    </div>

    <div class="card box-shadow" style="background:#111827; border:1px solid rgba(255,255,255,.12);">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-lg-5">
                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl"
                             alt="@Model.Name"
                             class="img-fluid rounded border"
                             style="border-color:rgba(255,255,255,.15)!important;" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center rounded"
                             style="height:320px; background:#0b1220; border:1px dashed rgba(255,255,255,.25);">
                            <span class="text-white-50">No image</span>
                        </div>
                    }
                </div>

                <div class="col-12 col-lg-7">
                    <h3 class="mb-2" style="color:#61dafb;">@Model.Name</h3>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @if (!string.IsNullOrWhiteSpace(Model.Brand))
                        {
                            <span class="meta-pill">@Model.Brand</span>
                        }
                        <span class="meta-pill">@Model.PartType</span>
                    </div>

                    <div class="fs-4 fw-bold mb-3">$@Model.Price</div>

                    <div class="desc-card mt-2">
                        <div class="desc-title">Description</div>
                        @if (!string.IsNullOrWhiteSpace(Model.Description))
                        {
                            <div class="desc-text">@Model.Description</div>
                        }
                        else
                        {
                            <div class="desc-text text-white-50">No description yet.</div>
                        }
                    </div>

                    @if (Model.Specs != null && Model.Specs.Count > 0)
                    {
                        <h5 class="mt-4 mb-2" style="color:#61dafb;">Specifications</h5>
                        <partial name="_SpecTable" model="Model" />
                    }
                    else
                    {
                        <h5 class="mt-4 mb-2" style="color:#61dafb;">Specifications</h5>
                        <div class="text-white-50">No specs available.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>