@model Demo.Models.Build

@{
    ViewData["Title"] = "Create Build";
}

<h1 class="mb-4 text-center"><i class="fa-solid fa-plus-circle"></i> Create Build</h1>

<div class="card card-glow p-4">
    <form asp-action="Create" method="post" id="buildForm">
        <div class="mb-3">
            <label asp-for="BuildName" class="form-label"></label>
            <input asp-for="BuildName" class="form-control" />
            <span asp-validation-for="BuildName" class="text-danger"></span>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label for="sortMode" class="form-label">Sort parts</label>
                <select id="sortMode" class="form-select">
                    <option value="default">Default order</option>
                    <option value="nameAsc">Name: A to Z</option>
                    <option value="nameDesc">Name: Z to A</option>
                    <option value="priceAsc">Price: Low to High</option>
                    <option value="priceDesc">Price: High to Low</option>
                </select>
            </div>

            <div class="col-md-6">
                <label for="priceFilter" class="form-label">Price filter</label>
                <select id="priceFilter" class="form-select">
                    <option value="all">All prices</option>
                    <option value="budget">Budget</option>
                    <option value="mid">Mid-range</option>
                    <option value="high">High-end</option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="CPUId" class="form-label"></label>
                <select asp-for="CPUId" asp-items="ViewBag.CPUId" class="form-select part-dropdown"></select>
                <span asp-validation-for="CPUId" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="GPUId" class="form-label"></label>
                <select asp-for="GPUId" asp-items="ViewBag.GPUId" class="form-select part-dropdown"></select>
                <span asp-validation-for="GPUId" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="MotherboardId" class="form-label"></label>
                <select asp-for="MotherboardId" asp-items="ViewBag.MotherboardId" class="form-select part-dropdown"></select>
                <span asp-validation-for="MotherboardId" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="RAMId" class="form-label"></label>
                <select asp-for="RAMId" asp-items="ViewBag.RAMId" class="form-select part-dropdown"></select>
                <span asp-validation-for="RAMId" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="StorageId" class="form-label"></label>
                <select asp-for="StorageId" asp-items="ViewBag.StorageId" class="form-select part-dropdown"></select>
                <span asp-validation-for="StorageId" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="PowerSupplyId" class="form-label"></label>
                <select asp-for="PowerSupplyId" asp-items="ViewBag.PowerSupplyId" class="form-select part-dropdown"></select>
                <span asp-validation-for="PowerSupplyId" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="CaseId" class="form-label"></label>
                <select asp-for="CaseId" asp-items="ViewBag.CaseId" class="form-select part-dropdown"></select>
                <span asp-validation-for="CaseId" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <strong>Total Price:</strong>
            <span id="totalPrice">$0.00</span>
        </div>

        <button type="submit" class="btn btn-fancy">
            <i class="fa-solid fa-save"></i> Save Build
        </button>
        <a asp-action="Index" class="btn btn-outline-light ms-2">Back</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const originalOptions = new Map();

        document.addEventListener('DOMContentLoaded', function () {
            const dropdowns = document.querySelectorAll('.part-dropdown');

            dropdowns.forEach(select => {
                const items = [];

                Array.from(select.options).forEach(option => {
                    if (!option.value) {
                        items.push({
                            value: option.value,
                            name: option.textContent.trim(),
                            price: 0,
                            isPlaceholder: true
                        });
                        return;
                    }

                    const parts = option.textContent.split('|');
                    const name = (parts[0] || '').trim();
                    const price = parseFloat(parts[1] || '0');

                    items.push({
                        value: option.value,
                        name: name,
                        price: isNaN(price) ? 0 : price,
                        isPlaceholder: false
                    });
                });

                originalOptions.set(select.id, items);
            });

            function getPriceBand(price, prices) {
                if (!prices.length) return 'all';

                const min = Math.min(...prices);
                const max = Math.max(...prices);
                const range = max - min;

                if (range <= 0) return 'mid';

                const budgetCutoff = min + range * 0.4;
                const highCutoff = min + range * 0.6;

                if (price <= budgetCutoff) return 'budget';
                if (price >= highCutoff) return 'high';
                return 'mid';
            }

            function rebuildDropdown(select) {
                const items = originalOptions.get(select.id) || [];
                const currentValue = select.value;
                const sortMode = document.getElementById('sortMode').value;
                const priceFilter = document.getElementById('priceFilter').value;

                const placeholder = items.find(x => x.isPlaceholder);
                let realItems = items.filter(x => !x.isPlaceholder);

                const allPrices = realItems.map(x => x.price).filter(x => x > 0);

                if (priceFilter !== 'all') {
                    realItems = realItems.filter(x => getPriceBand(x.price, allPrices) === priceFilter);
                }

                if (sortMode === 'nameAsc') {
                    realItems.sort((a, b) => a.name.localeCompare(b.name));
                } else if (sortMode === 'nameDesc') {
                    realItems.sort((a, b) => b.name.localeCompare(a.name));
                } else if (sortMode === 'priceAsc') {
                    realItems.sort((a, b) => a.price - b.price);
                } else if (sortMode === 'priceDesc') {
                    realItems.sort((a, b) => b.price - a.price);
                }

                select.innerHTML = '';

                if (placeholder) {
                    const option = document.createElement('option');
                    option.value = placeholder.value;
                    option.textContent = placeholder.name;
                    select.appendChild(option);
                }

                realItems.forEach(item => {
                    const option = document.createElement('option');
                    option.value = item.value;
                    option.textContent = `${item.name} - $${item.price.toFixed(2)}`;
                    option.dataset.price = item.price;
                    select.appendChild(option);
                });

                if (currentValue && select.querySelector(`option[value="${currentValue}"]`)) {
                    select.value = currentValue;
                }
            }

            function rebuildAllDropdowns() {
                dropdowns.forEach(rebuildDropdown);
                calculateTotal();
            }

            function calculateTotal() {
                let total = 0;

                dropdowns.forEach(select => {
                    const selected = select.options[select.selectedIndex];
                    if (selected && selected.dataset.price) {
                        total += parseFloat(selected.dataset.price || '0');
                    }
                });

                document.getElementById('totalPrice').textContent = `$${total.toFixed(2)}`;
            }

            dropdowns.forEach(select => {
                select.addEventListener('change', calculateTotal);
            });

            document.getElementById('sortMode').addEventListener('change', rebuildAllDropdowns);
            document.getElementById('priceFilter').addEventListener('change', rebuildAllDropdowns);

            rebuildAllDropdowns();
        });
    </script>
}