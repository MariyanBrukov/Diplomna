@model IEnumerable<Demo.Models.Contact>

@{
    ViewData["Title"] = "Support Tickets";
}

<div class="container py-5 fade-in">
    <h1 class="text-center mb-4 text-info fw-bold">
        <i class="fa-solid fa-headset me-2"></i> Support Tickets
    </h1>

    @if (!Model.Any())
    {
        <div class="text-center text-light mt-5">
            <i class="fa-solid fa-inbox fa-3x mb-3 text-info"></i>
            <h4>No tickets yet</h4>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card card-glow h-100 p-4 position-relative">

                        <!-- STATUS BADGE -->
                        <div class="position-absolute top-0 end-0 m-3">
                            @if (item.IsAnswered)
                            {
                                <span class="badge bg-success">Answered</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </div>

                        <h5 class="text-info fw-semibold mb-2">
                            <i class="fa-solid fa-user me-1"></i> @item.Name
                        </h5>

                        <div class="text-light small mb-2">
                            <strong>Email:</strong>
                            <span class="text-white-50">@item.Email</span>
                        </div>

                        <div class="text-light small mb-2">
                            <strong>Subject:</strong>
                            <span class="text-white-50">@item.Subject</span>
                        </div>

                        <div class="text-white-50 small mb-3" style="max-height:80px; overflow:hidden;">
                            @item.Message
                        </div>

                        <div class="text-white-50 small mb-3">
                            <i class="fa-regular fa-clock me-1"></i>
                            @item.CreatedAt.ToString("g")
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-auto">
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-info"
                               title="View / Reply">
                                <i class="fa-solid fa-reply"></i>
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger"
                               title="Delete">
                                <i class="fa-solid fa-trash"></i>
                            </a>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>