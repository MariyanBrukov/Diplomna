@using Microsoft.AspNetCore.Http
@using Demo.Models.ViewModels

@{
    var username = Context.Session.GetString("Username");
    var isLoggedIn = !string.IsNullOrEmpty(username);
    var isAdmin = Context.Session.GetString("IsAdmin") == "True";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PC Junkie</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
        :root {
            --primary-accent: #61dafb;
            --primary-accent-2: #8ae8ff;
            --background-main: #0f1422;
            --background-main-2: #181c27;
            --background-card: #212633;
            --background-card-2: #1a2030;
            --text-main: #f1f3f6;
            --text-muted: #cfd2d8;
            --text-soft: rgba(241, 243, 246, 0.72);
            --border-soft: rgba(255, 255, 255, 0.08);
            --border-strong: rgba(97, 218, 251, 0.18);
            --admin-accent: #ffb703;
            --danger-accent: #ff6b6b;
            --nav-height: 84px;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at 25% 25%, #1a1f2d, transparent 30%), radial-gradient(circle at 80% 20%, rgba(97, 218, 251, 0.06), transparent 24%), radial-gradient(circle at 50% 85%, rgba(124, 77, 255, 0.06), transparent 26%), linear-gradient(135deg, #0c111d, #111522, #161c2b);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        header {
            position: sticky;
            top: 0;
            z-index: 5000;
            overflow: visible !important;
        }

        nav.navbar {
            position: relative;
            z-index: 5001;
            background: rgba(20, 25, 38, 0.82);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border-soft);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35), 0 0 20px rgba(97, 218, 251, 0.05);
            min-height: var(--nav-height);
            overflow: visible !important;
        }

        .navbar > .container,
        .navbar-collapse,
        .navbar-nav,
        .nav-item.dropdown {
            overflow: visible !important;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.4rem;
            color: var(--primary-accent) !important;
            letter-spacing: 0.4px;
            text-shadow: 0 0 12px rgba(97, 218, 251, 0.18);
            transition: transform 0.22s ease, text-shadow 0.22s ease;
        }

            .navbar-brand:hover {
                transform: translateY(-1px);
                text-shadow: 0 0 18px rgba(97, 218, 251, 0.28);
            }

        .navbar-nav .nav-link {
            color: var(--text-muted) !important;
            margin: 0 0.22rem;
            transition: all 0.25s ease-in-out;
            font-weight: 600;
            border-radius: 999px;
            padding: 0.65rem 1rem !important;
            position: relative;
        }

            .navbar-nav .nav-link:hover,
            .navbar-nav .nav-link:focus {
                color: var(--primary-accent) !important;
                transform: translateY(-2px);
                background: rgba(97, 218, 251, 0.07);
            }

            .navbar-nav .nav-link.active,
            .navbar-nav .show > .nav-link {
                color: #ffffff !important;
                background: rgba(97, 218, 251, 0.12);
                box-shadow: inset 0 0 0 1px rgba(97, 218, 251, 0.10);
            }

        .navbar-toggler {
            border-color: rgba(255, 255, 255, 0.18);
            box-shadow: none !important;
            padding: 0.5rem 0.75rem;
            border-radius: 14px;
            background: rgba(255,255,255,0.03);
        }

            .navbar-toggler:focus {
                box-shadow: 0 0 0 0.2rem rgba(97, 218, 251, 0.14) !important;
            }

        .navbar-toggler-icon {
            filter: brightness(1.15);
        }

        .content-wrapper {
            position: relative;
            z-index: 1;
            flex: 1;
            padding: 2rem 1.5rem 3rem;
        }

            .content-wrapper > .container {
                position: relative;
                z-index: 1;
            }

        .card-glow {
            background: linear-gradient(145deg, rgba(33, 38, 51, 0.92), rgba(26, 32, 48, 0.92));
            border: 1px solid var(--border-soft);
            border-radius: 18px;
            box-shadow: 0 0 15px rgba(97, 218, 251, 0.08);
            transition: all 0.3s ease;
            color: var(--text-main);
        }

            .card-glow:hover {
                box-shadow: 0 0 28px rgba(97, 218, 251, 0.20);
                transform: translateY(-3px);
            }

        .btn-fancy {
            background: linear-gradient(135deg, var(--primary-accent), #007bff);
            border: none;
            border-radius: 999px;
            color: #06111b;
            padding: 0.68rem 1.45rem;
            transition: all 0.25s ease;
            font-weight: 700;
            letter-spacing: 0.2px;
            box-shadow: 0 0 18px rgba(97, 218, 251, 0.16);
        }

            .btn-fancy:hover {
                background: linear-gradient(135deg, #00b4d8, #0a58ca);
                transform: scale(1.04) translateY(-1px);
                color: #fff;
            }

        .table-dark-custom {
            background: rgba(36, 40, 56, 0.9);
            border-radius: 12px;
            overflow: hidden;
            color: var(--text-main);
        }

            .table-dark-custom th {
                color: var(--primary-accent);
                background-color: rgba(255, 255, 255, 0.05);
            }

            .table-dark-custom tr:hover {
                background: rgba(97, 218, 251, 0.08);
            }

        footer {
            position: relative;
            z-index: 2;
            margin-top: auto;
            background: rgba(20, 24, 36, 0.92);
            color: var(--text-muted);
            padding: 1.35rem 0;
            text-align: center;
            font-size: 0.92rem;
            border-top: 1px solid var(--border-soft);
            box-shadow: 0 -8px 20px rgba(0, 0, 0, 0.18);
        }

            footer a {
                color: var(--primary-accent);
                text-decoration: none;
                font-weight: 600;
            }

                footer a:hover {
                    text-decoration: underline;
                }

        a {
            text-decoration: none;
            color: var(--primary-accent);
        }

            a:hover {
                text-decoration: underline;
            }

        .fade-in {
            animation: fadeIn 0.5s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .user-pill {
            color: #61dafb !important;
            font-weight: 700;
        }

        .admin-pill {
            color: var(--admin-accent) !important;
            font-weight: 800;
        }

        .admin-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #ffb703, #fb8500);
            color: #111;
            font-size: 0.68rem;
            border-radius: 999px;
            padding: 0.22rem 0.5rem;
            font-weight: 800;
            margin-left: 0.38rem;
            vertical-align: middle;
            box-shadow: 0 0 10px rgba(255, 183, 3, 0.22);
        }

        .dropdown-menu-dark-custom {
            --bs-dropdown-min-width: 240px;
            background: rgba(23, 29, 42, 0.98);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 18px;
            padding: 0.55rem;
            box-shadow: 0 18px 40px rgba(0,0,0,0.35), 0 0 18px rgba(97, 218, 251, 0.08);
            z-index: 7000 !important;
            margin-top: 0.65rem !important;
        }

            .dropdown-menu-dark-custom .dropdown-item {
                color: #f1f3f6;
                border-radius: 12px;
                padding: 0.7rem 0.85rem;
                font-weight: 600;
                transition: all 0.18s ease;
            }

                .dropdown-menu-dark-custom .dropdown-item:hover,
                .dropdown-menu-dark-custom .dropdown-item:focus {
                    background: rgba(97, 218, 251, 0.12);
                    color: #fff;
                }

        .dropdown-divider {
            border-top-color: rgba(255,255,255,0.08) !important;
            opacity: 1;
        }

        .dropdown-toggle::after {
            margin-left: 0.45rem;
        }

        .modal {
            z-index: 8000 !important;
        }

        .modal-backdrop {
            z-index: 7990 !important;
        }

        .modal-content-dark {
            background: #1b2230;
            color: #f1f3f6;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 18px;
            box-shadow: 0 0 30px rgba(0,0,0,0.45);
        }

        .admin-login-btn {
            border: 1px solid rgba(255, 183, 3, 0.5);
            color: #ffb703 !important;
            border-radius: 999px;
            padding: 0.65rem 1rem !important;
        }

            .admin-login-btn:hover {
                background: rgba(255,183,3,0.12) !important;
                color: #ffd166 !important;
            }

        .alert {
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.08);
        }

        .form-control,
        .form-select {
            border-radius: 14px;
        }

            .form-control:focus,
            .form-select:focus {
                border-color: rgba(97, 218, 251, 0.55);
                box-shadow: 0 0 0 0.18rem rgba(97, 218, 251, 0.14);
            }

        @@media (max-width: 991.98px) {
            .navbar-collapse {
                margin-top: 1rem;
                padding: 1rem;
                border-radius: 20px;
                background: rgba(18, 24, 38, 0.96);
                border: 1px solid rgba(255,255,255,0.08);
                box-shadow: 0 18px 40px rgba(0,0,0,0.26);
            }

            .navbar-nav .nav-link,
            .admin-login-btn {
                width: 100%;
                text-align: left;
            }

            .dropdown-menu-dark-custom {
                position: static !important;
                transform: none !important;
                width: 100%;
                margin-top: 0.5rem !important;
                box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04);
            }

            .content-wrapper {
                padding: 1.5rem 0.75rem 2.5rem;
            }
        }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark py-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-computer me-1"></i> PC Junkie
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNav"
                        aria-controls="mainNav"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-house me-1"></i> Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Browse" asp-action="Index">
                                <i class="fa-solid fa-microchip me-1"></i> Browse
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Builds" asp-action="Index">
                                <i class="fa-solid fa-screwdriver-wrench me-1"></i> My Builds
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Builds" asp-action="Create">
                                <i class="fa-solid fa-plus-circle me-1"></i> New Build
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contacts" asp-action="Create">
                                <i class="fa-solid fa-envelope me-1"></i> Contact
                            </a>
                        </li>

                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link admin-pill" asp-controller="Contacts" asp-action="Index">
                                    <i class="fa-solid fa-headset me-1"></i> Admin Tickets
                                </a>
                            </li>
                        }

                        @if (isLoggedIn)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isAdmin ? "admin-pill" : "user-pill")"
                                   href="#"
                                   id="userDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    <i class="fa-solid fa-user me-1"></i> @username
                                    @if (isAdmin)
                                    {
                                        <span class="admin-badge">ADMIN</span>
                                    }
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark-custom" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Builds" asp-action="Index">
                                            <i class="fa-solid fa-folder-open me-2"></i> My Builds
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Builds" asp-action="Create">
                                            <i class="fa-solid fa-plus me-2"></i> Create Build
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Contacts" asp-action="Create">
                                            <i class="fa-solid fa-envelope me-2"></i> Contact Support
                                        </a>
                                    </li>

                                    @if (isAdmin)
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <a class="dropdown-item text-warning" asp-controller="Contacts" asp-action="Index">
                                                <i class="fa-solid fa-headset me-2"></i> Manage Tickets
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item text-warning" asp-controller="Browse" asp-action="Index">
                                                <i class="fa-solid fa-pen-to-square me-2"></i> Manage Browse Items
                                            </a>
                                        </li>
                                    }

                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                            <i class="fa-solid fa-right-from-bracket me-2"></i> Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="fa-solid fa-right-to-bracket me-1"></i> Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="fa-solid fa-user-plus me-1"></i> Register
                                </a>
                            </li>

                            <li class="nav-item">
                                <button type="button"
                                        class="nav-link bg-transparent admin-login-btn"
                                        data-bs-toggle="modal"
                                        data-bs-target="#adminLoginModal">
                                    <i class="fa-solid fa-shield-halved me-1"></i> Admin Login
                                </button>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="content-wrapper fade-in">
        <div class="container">
            @if (TempData["AdminLoginError"] != null)
            {
                <div class="alert alert-danger mb-4">
                    @TempData["AdminLoginError"]
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <footer>
        <div class="container">
            <p class="mb-0">&copy; @DateTime.Now.Year - <a asp-controller="Home" asp-action="Index">PC Junkie</a></p>
        </div>
    </footer>

    @if (!isLoggedIn)
    {
        <div class="modal fade" id="adminLoginModal" tabindex="-1" aria-labelledby="adminLoginModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content modal-content-dark">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title text-warning fw-bold" id="adminLoginModalLabel">
                            <i class="fa-solid fa-shield-halved me-2"></i> Admin Login
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <form asp-controller="Account" asp-action="AdminLogin" method="post">
                        @Html.AntiForgeryToken()

                        <div class="modal-body">
                            <p class="text-white-50 mb-4">
                                Sign in as administrator to manage browse items and support tickets.
                            </p>

                            <div class="mb-3">
                                <label class="form-label text-light">Email</label>
                                <input name="Email"
                                       type="email"
                                       class="form-control bg-dark text-light border-secondary"
                                       placeholder="admin@example.com"
                                       required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-light">Password</label>
                                <input name="Password"
                                       type="password"
                                       class="form-control bg-dark text-light border-secondary"
                                       placeholder="Enter admin password"
                                       required />
                            </div>
                        </div>

                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-warning rounded-pill px-4 fw-semibold text-dark">
                                <i class="fa-solid fa-right-to-bracket me-1"></i> Admin Login
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @if (TempData["AdminLoginError"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var modalElement = document.getElementById('adminLoginModal');
                if (modalElement) {
                    var modal = new bootstrap.Modal(modalElement);
                    modal.show();
                }
            });
        </script>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>