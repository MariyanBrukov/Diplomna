@using Microsoft.AspNetCore.Http
@using Demo.Models.ViewModels

@{
    var username = Context.Session.GetString("Username");
    var isLoggedIn = !string.IsNullOrEmpty(username);
    var isAdmin = Context.Session.GetString("IsAdmin") == "True";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PC Junkie</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --primary-accent: #61dafb;
            --background-main: #181c27;
            --background-card: #212633;
            --text-main: #f1f3f6;
            --text-muted: #cfd2d8;
            --border-soft: rgba(255, 255, 255, 0.08);
            --admin-accent: #ffb703;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at 25% 25%, #1a1f2d, #111522);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        nav.navbar {
            background: rgba(34, 39, 54, 0.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-soft);
            box-shadow: 0 0 25px rgba(0, 0, 0, 0.5);
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.4rem;
            color: var(--primary-accent) !important;
            letter-spacing: 0.5px;
        }

        .navbar-nav .nav-link {
            color: var(--text-muted) !important;
            margin: 0 0.4rem;
            transition: all 0.3s ease-in-out;
            font-weight: 500;
        }

            .navbar-nav .nav-link:hover {
                color: var(--primary-accent) !important;
                transform: translateY(-2px);
            }

        .navbar-toggler {
            border-color: rgba(255, 255, 255, 0.3);
        }

        .content-wrapper {
            flex: 1;
            padding: 2.5rem 1.5rem;
        }

        .card-glow {
            background: var(--background-card);
            border: 1px solid var(--border-soft);
            border-radius: 16px;
            box-shadow: 0 0 15px rgba(97, 218, 251, 0.1);
            transition: all 0.3s ease;
            color: var(--text-main);
        }

            .card-glow:hover {
                box-shadow: 0 0 30px rgba(97, 218, 251, 0.35);
                transform: translateY(-3px);
            }

        .btn-fancy {
            background: linear-gradient(135deg, var(--primary-accent), #007bff);
            border: none;
            border-radius: 50px;
            color: #fff;
            padding: 0.6rem 1.4rem;
            transition: all 0.25s ease;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

            .btn-fancy:hover {
                background: linear-gradient(135deg, #00b4d8, #0a58ca);
                transform: scale(1.05);
            }

        .table-dark-custom {
            background: rgba(36, 40, 56, 0.9);
            border-radius: 10px;
            overflow: hidden;
            color: var(--text-main);
        }

            .table-dark-custom th {
                color: var(--primary-accent);
                background-color: rgba(255, 255, 255, 0.05);
            }

            .table-dark-custom tr:hover {
                background: rgba(97, 218, 251, 0.08);
            }

        footer {
            margin-top: auto;
            background: rgba(28, 32, 45, 0.95);
            color: var(--text-muted);
            padding: 1.5rem 0;
            text-align: center;
            font-size: 0.9rem;
            border-top: 1px solid var(--border-soft);
        }

            footer a {
                color: var(--primary-accent);
                text-decoration: none;
            }

                footer a:hover {
                    text-decoration: underline;
                }

        a {
            text-decoration: none;
            color: var(--primary-accent);
        }

            a:hover {
                text-decoration: underline;
            }

        .fade-in {
            animation: fadeIn 0.5s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .user-pill {
            color: #61dafb !important;
            font-weight: 600;
        }

        .admin-pill {
            color: var(--admin-accent) !important;
            font-weight: 700;
        }

        .admin-badge {
            background: linear-gradient(135deg, #ffb703, #fb8500);
            color: #111;
            font-size: 0.7rem;
            border-radius: 999px;
            padding: 0.2rem 0.5rem;
            font-weight: 700;
            margin-left: 0.35rem;
            vertical-align: middle;
        }

        .dropdown-menu-dark-custom {
            background: #1f2430;
            border: 1px solid rgba(255,255,255,0.08);
        }

            .dropdown-menu-dark-custom .dropdown-item {
                color: #f1f3f6;
            }

                .dropdown-menu-dark-custom .dropdown-item:hover {
                    background: rgba(97, 218, 251, 0.12);
                    color: #fff;
                }

        .modal-content-dark {
            background: #1b2230;
            color: #f1f3f6;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 18px;
            box-shadow: 0 0 30px rgba(0,0,0,0.45);
        }

        .admin-login-btn {
            border: 1px solid rgba(255, 183, 3, 0.5);
            color: #ffb703 !important;
        }

            .admin-login-btn:hover {
                background: rgba(255,183,3,0.12);
                color: #ffd166 !important;
            }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark py-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-computer"></i> PC Junkie
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-house"></i> Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Browse" asp-action="Index">
                                <i class="fa-solid fa-microchip"></i> Browse
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Builds" asp-action="Index">
                                <i class="fa-solid fa-screwdriver-wrench"></i> My Builds
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Builds" asp-action="Create">
                                <i class="fa-solid fa-plus-circle"></i> New Build
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contacts" asp-action="Create">
                                <i class="fa-solid fa-envelope"></i> Contact
                            </a>
                        </li>

                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link admin-pill" asp-controller="Contacts" asp-action="Index">
                                    <i class="fa-solid fa-headset"></i> Admin Tickets
                                </a>
                            </li>
                        }

                        @if (isLoggedIn)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isAdmin ? "admin-pill" : "user-pill")"
                                   href="#"
                                   id="userDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    <i class="fa-solid fa-user"></i> @username
                                    @if (isAdmin)
                                    {
                                        <span class="admin-badge">ADMIN</span>
                                    }
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark-custom">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Builds" asp-action="Index">
                                            <i class="fa-solid fa-folder-open"></i> My Builds
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Builds" asp-action="Create">
                                            <i class="fa-solid fa-plus"></i> Create Build
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Contacts" asp-action="Create">
                                            <i class="fa-solid fa-envelope"></i> Contact Support
                                        </a>
                                    </li>

                                    @if (isAdmin)
                                    {
                                        <li><hr class="dropdown-divider text-secondary" /></li>
                                        <li>
                                            <a class="dropdown-item text-warning" asp-controller="Contacts" asp-action="Index">
                                                <i class="fa-solid fa-headset"></i> Manage Tickets
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item text-warning" asp-controller="Browse" asp-action="Index">
                                                <i class="fa-solid fa-pen-to-square"></i> Manage Browse Items
                                            </a>
                                        </li>
                                    }

                                    <li><hr class="dropdown-divider text-secondary" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                            <i class="fa-solid fa-right-from-bracket"></i> Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="fa-solid fa-right-to-bracket"></i> Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="fa-solid fa-user-plus"></i> Register
                                </a>
                            </li>

                            <li class="nav-item">
                                <button type="button"
                                        class="nav-link bg-transparent border-0 admin-login-btn"
                                        data-bs-toggle="modal"
                                        data-bs-target="#adminLoginModal">
                                    <i class="fa-solid fa-shield-halved"></i> Admin Login
                                </button>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="content-wrapper fade-in">
        <div class="container">
            @if (TempData["AdminLoginError"] != null)
            {
                <div class="alert alert-danger mb-4">
                    @TempData["AdminLoginError"]
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <footer>
        <div class="container">
            <p>&copy; @DateTime.Now.Year - <a asp-controller="Home" asp-action="Index">PC Junkie</a></p>
        </div>
    </footer>

    @if (!isLoggedIn)
    {
        <div class="modal fade" id="adminLoginModal" tabindex="-1" aria-labelledby="adminLoginModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content modal-content-dark">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title text-warning fw-bold" id="adminLoginModalLabel">
                            <i class="fa-solid fa-shield-halved me-2"></i> Admin Login
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <form asp-controller="Account" asp-action="AdminLogin" method="post">
                        @Html.AntiForgeryToken()

                        <div class="modal-body">
                            <p class="text-white-50 mb-4">
                                Sign in as administrator to manage browse items and support tickets.
                            </p>

                            <div class="mb-3">
                                <label class="form-label text-light">Email</label>
                                <input name="Email"
                                       type="email"
                                       class="form-control bg-dark text-light border-secondary"
                                       placeholder="admin@example.com"
                                       required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-light">Password</label>
                                <input name="Password"
                                       type="password"
                                       class="form-control bg-dark text-light border-secondary"
                                       placeholder="Enter admin password"
                                       required />
                            </div>
                        </div>

                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-warning rounded-pill px-4 fw-semibold text-dark">
                                <i class="fa-solid fa-right-to-bracket"></i> Admin Login
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @if (TempData["AdminLoginError"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var modalElement = document.getElementById('adminLoginModal');
                if (modalElement) {
                    var modal = new bootstrap.Modal(modalElement);
                    modal.show();
                }
            });
        </script>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>