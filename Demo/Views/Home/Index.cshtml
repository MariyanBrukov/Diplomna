@{
    ViewData["Title"] = "Home";
}

<style>
    :root {
        --bg-1: #0a0f1f;
        --bg-2: #11182d;
        --bg-3: #1a2340;
        --card-bg: rgba(20, 28, 48, 0.78);
        --card-border: rgba(97, 218, 251, 0.18);
        --accent: #61dafb;
        --accent-2: #7c4dff;
        --accent-3: #00e5ff;
        --text-main: #f4f8ff;
        --text-soft: rgba(244, 248, 255, 0.72);
        --text-faded: rgba(244, 248, 255, 0.5);
        --shadow-blue: 0 0 30px rgba(97, 218, 251, 0.22);
        --shadow-purple: 0 0 40px rgba(124, 77, 255, 0.18);
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: radial-gradient(circle at 20% 20%, rgba(97, 218, 251, 0.08), transparent 25%), radial-gradient(circle at 80% 30%, rgba(124, 77, 255, 0.10), transparent 25%), radial-gradient(circle at 50% 80%, rgba(0, 229, 255, 0.08), transparent 25%), linear-gradient(135deg, var(--bg-1), var(--bg-2), var(--bg-3));
        color: var(--text-main);
        overflow-x: hidden;
    }

    .pcj-home-wrapper {
        position: relative;
        isolation: isolate;
        overflow: hidden;
    }

        .pcj-home-wrapper::before {
            content: "";
            position: fixed;
            inset: 0;
            background: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
            background-size: 42px 42px;
            mask-image: radial-gradient(circle at center, black 35%, transparent 88%);
            z-index: -5;
            animation: gridShift 18s linear infinite;
            pointer-events: none;
        }

    .bg-orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(70px);
        opacity: 0.45;
        z-index: -4;
        pointer-events: none;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        animation-direction: alternate;
    }

    .orb-1 {
        width: 380px;
        height: 380px;
        top: 6%;
        left: -6%;
        background: rgba(97, 218, 251, 0.22);
        animation: floatOrb1 9s infinite;
    }

    .orb-2 {
        width: 420px;
        height: 420px;
        top: 42%;
        right: -10%;
        background: rgba(124, 77, 255, 0.18);
        animation: floatOrb2 12s infinite;
    }

    .orb-3 {
        width: 300px;
        height: 300px;
        bottom: -4%;
        left: 28%;
        background: rgba(0, 229, 255, 0.16);
        animation: floatOrb3 11s infinite;
    }

    .particles {
        position: fixed;
        inset: 0;
        z-index: -3;
        pointer-events: none;
        overflow: hidden;
    }

    .particle {
        position: absolute;
        bottom: -20px;
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: rgba(97, 218, 251, 0.85);
        box-shadow: 0 0 10px rgba(97, 218, 251, 0.8);
        animation: rise linear infinite;
    }

        .particle:nth-child(1) {
            left: 4%;
            animation-duration: 12s;
            animation-delay: 0s;
            transform: scale(1.0);
        }

        .particle:nth-child(2) {
            left: 10%;
            animation-duration: 15s;
            animation-delay: 3s;
            transform: scale(1.4);
        }

        .particle:nth-child(3) {
            left: 16%;
            animation-duration: 18s;
            animation-delay: 2s;
            transform: scale(0.8);
        }

        .particle:nth-child(4) {
            left: 24%;
            animation-duration: 14s;
            animation-delay: 6s;
            transform: scale(1.2);
        }

        .particle:nth-child(5) {
            left: 31%;
            animation-duration: 16s;
            animation-delay: 1s;
            transform: scale(1.0);
        }

        .particle:nth-child(6) {
            left: 39%;
            animation-duration: 13s;
            animation-delay: 5s;
            transform: scale(1.5);
        }

        .particle:nth-child(7) {
            left: 47%;
            animation-duration: 17s;
            animation-delay: 7s;
            transform: scale(0.9);
        }

        .particle:nth-child(8) {
            left: 56%;
            animation-duration: 15s;
            animation-delay: 2.5s;
            transform: scale(1.2);
        }

        .particle:nth-child(9) {
            left: 63%;
            animation-duration: 19s;
            animation-delay: 4s;
            transform: scale(0.7);
        }

        .particle:nth-child(10) {
            left: 71%;
            animation-duration: 12s;
            animation-delay: 1.5s;
            transform: scale(1.1);
        }

        .particle:nth-child(11) {
            left: 79%;
            animation-duration: 18s;
            animation-delay: 3.5s;
            transform: scale(1.4);
        }

        .particle:nth-child(12) {
            left: 87%;
            animation-duration: 16s;
            animation-delay: 6.5s;
            transform: scale(0.8);
        }

        .particle:nth-child(13) {
            left: 93%;
            animation-duration: 14s;
            animation-delay: 5.5s;
            transform: scale(1.1);
        }

        .particle:nth-child(14) {
            left: 52%;
            animation-duration: 20s;
            animation-delay: 8s;
            transform: scale(1.6);
        }

        .particle:nth-child(15) {
            left: 67%;
            animation-duration: 21s;
            animation-delay: 10s;
            transform: scale(0.95);
        }

    .hero-section {
        position: relative;
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        padding: 5rem 0 3rem;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        padding: .6rem 1rem;
        border-radius: 999px;
        background: rgba(97, 218, 251, 0.08);
        border: 1px solid rgba(97, 218, 251, 0.22);
        color: var(--accent);
        font-weight: 700;
        letter-spacing: .04em;
        text-transform: uppercase;
        box-shadow: var(--shadow-blue);
        backdrop-filter: blur(12px);
        animation: pulseSoft 3s infinite ease-in-out;
    }

    .hero-title {
        font-size: clamp(2.6rem, 7vw, 6rem);
        line-height: 0.95;
        font-weight: 900;
        letter-spacing: -0.04em;
        margin: 1.25rem 0 1rem;
        text-transform: uppercase;
    }

    .title-glow {
        color: var(--accent);
        text-shadow: 0 0 12px rgba(97, 218, 251, 0.45), 0 0 32px rgba(97, 218, 251, 0.22);
    }

    .hero-subtitle {
        font-size: 1.08rem;
        color: var(--text-soft);
        max-width: 760px;
        line-height: 1.9;
    }

    .hero-actions {
        margin-top: 2rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .btn-main-glow,
    .btn-outline-glow {
        border-radius: 999px;
        padding: .95rem 1.65rem;
        font-weight: 800;
        letter-spacing: .02em;
        transition: transform .22s ease, box-shadow .22s ease, background .22s ease, border-color .22s ease;
        position: relative;
        overflow: hidden;
    }

    .btn-main-glow {
        color: #06111b;
        background: linear-gradient(90deg, var(--accent), #8ae8ff);
        border: none;
        box-shadow: 0 0 22px rgba(97, 218, 251, 0.30);
    }

        .btn-main-glow:hover {
            transform: translateY(-3px) scale(1.03);
            box-shadow: 0 0 34px rgba(97, 218, 251, 0.42);
            color: #06111b;
        }

    .btn-outline-glow {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(97, 218, 251, 0.32);
        color: var(--text-main);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03);
    }

        .btn-outline-glow:hover {
            transform: translateY(-3px) scale(1.03);
            border-color: rgba(97, 218, 251, 0.60);
            box-shadow: 0 0 28px rgba(97, 218, 251, 0.16);
            color: white;
        }

    .hero-mini-note {
        margin-top: 1.3rem;
        color: var(--text-faded);
        font-size: .95rem;
        letter-spacing: .02em;
    }

    .hero-visual {
        position: relative;
        min-height: 560px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .core-ring {
        position: absolute;
        border-radius: 50%;
        border: 1px solid rgba(97, 218, 251, 0.22);
        animation: spinSlow 16s linear infinite;
    }

    .ring-1 {
        width: 420px;
        height: 420px;
        box-shadow: 0 0 40px rgba(97, 218, 251, 0.08), inset 0 0 24px rgba(97, 218, 251, 0.04);
    }

    .ring-2 {
        width: 310px;
        height: 310px;
        border-color: rgba(124, 77, 255, 0.22);
        animation-direction: reverse;
        animation-duration: 13s;
    }

    .ring-3 {
        width: 220px;
        height: 220px;
        border-color: rgba(0, 229, 255, 0.30);
        animation-duration: 10s;
    }

    .cpu-core {
        position: relative;
        width: 220px;
        height: 220px;
        border-radius: 32px;
        background: linear-gradient(145deg, rgba(18, 28, 48, 0.98), rgba(28, 38, 64, 0.88));
        border: 1px solid rgba(97, 218, 251, 0.22);
        box-shadow: 0 0 50px rgba(97, 218, 251, 0.14), 0 0 90px rgba(124, 77, 255, 0.10), inset 0 0 45px rgba(255,255,255,0.03);
        display: flex;
        align-items: center;
        justify-content: center;
        animation: hoverCore 4s ease-in-out infinite;
    }

        .cpu-core::before,
        .cpu-core::after {
            content: "";
            position: absolute;
            inset: 14px;
            border-radius: 24px;
            border: 1px solid rgba(97, 218, 251, 0.15);
        }

        .cpu-core::after {
            inset: 28px;
            border-color: rgba(124, 77, 255, 0.12);
        }

    .cpu-inner {
        text-align: center;
        z-index: 2;
    }

        .cpu-inner i {
            font-size: 3.4rem;
            color: var(--accent);
            text-shadow: 0 0 16px rgba(97, 218, 251, 0.32);
            margin-bottom: .8rem;
            animation: pulseSoft 2.8s infinite ease-in-out;
        }

        .cpu-inner h2 {
            margin: 0;
            font-size: 1.45rem;
            font-weight: 900;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .cpu-inner p {
            margin: .5rem 0 0;
            color: var(--text-soft);
            font-size: .95rem;
        }

    .floating-chip {
        position: absolute;
        background: rgba(19, 28, 48, 0.90);
        border: 1px solid rgba(97, 218, 251, 0.18);
        border-radius: 18px;
        padding: .85rem 1rem;
        min-width: 150px;
        box-shadow: 0 0 24px rgba(97, 218, 251, 0.10);
        backdrop-filter: blur(12px);
    }

        .floating-chip strong {
            display: block;
            color: white;
            font-size: .95rem;
            margin-bottom: .2rem;
        }

        .floating-chip span {
            color: var(--text-faded);
            font-size: .84rem;
        }

    .chip-a {
        top: 12%;
        left: 6%;
        animation: floatCard 5s ease-in-out infinite;
    }

    .chip-b {
        top: 20%;
        right: 2%;
        animation: floatCard 6.2s ease-in-out infinite;
    }

    .chip-c {
        bottom: 16%;
        left: 1%;
        animation: floatCard 5.7s ease-in-out infinite;
    }

    .chip-d {
        bottom: 8%;
        right: 7%;
        animation: floatCard 6.8s ease-in-out infinite;
    }

    .section-block {
        position: relative;
        padding: 2rem 0 1rem;
    }

    .section-heading {
        text-align: center;
        margin-bottom: 2.4rem;
    }

        .section-heading .eyebrow {
            display: inline-block;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: .12em;
            font-size: .82rem;
            font-weight: 800;
            margin-bottom: .7rem;
        }

        .section-heading h2 {
            font-size: clamp(1.9rem, 5vw, 3.1rem);
            font-weight: 900;
            margin-bottom: .75rem;
        }

        .section-heading p {
            color: var(--text-soft);
            max-width: 760px;
            margin: 0 auto;
            line-height: 1.8;
        }

    .glass-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 28px;
        box-shadow: 0 14px 50px rgba(0,0,0,0.20), inset 0 0 0 1px rgba(255,255,255,0.02);
        backdrop-filter: blur(16px);
        transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
        overflow: hidden;
        height: 100%;
    }

        .glass-card:hover {
            transform: translateY(-8px);
            border-color: rgba(97, 218, 251, 0.34);
            box-shadow: 0 20px 60px rgba(0,0,0,0.30), 0 0 35px rgba(97, 218, 251, 0.12);
        }

    .feature-card {
        padding: 2rem 1.5rem;
        position: relative;
    }

    .feature-icon {
        width: 72px;
        height: 72px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 22px;
        margin-bottom: 1.2rem;
        color: var(--accent);
        background: linear-gradient(145deg, rgba(97, 218, 251, 0.10), rgba(124, 77, 255, 0.12));
        border: 1px solid rgba(97, 218, 251, 0.18);
        box-shadow: 0 0 24px rgba(97, 218, 251, 0.10);
        font-size: 1.6rem;
    }

    .feature-card h4 {
        font-weight: 800;
        margin-bottom: .8rem;
    }

    .feature-card p {
        color: var(--text-soft);
        margin-bottom: 0;
        line-height: 1.8;
    }

    .stat-strip {
        margin: 4rem 0;
        padding: 1.2rem;
        border-radius: 28px;
        background: rgba(14, 20, 36, 0.72);
        border: 1px solid rgba(97, 218, 251, 0.12);
        box-shadow: var(--shadow-purple);
    }

    .stat-box {
        text-align: center;
        padding: 1.2rem;
        border-radius: 22px;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.03);
        height: 100%;
    }

        .stat-box h3 {
            font-size: 2rem;
            font-weight: 900;
            color: var(--accent);
            margin-bottom: .35rem;
        }

        .stat-box p {
            margin: 0;
            color: var(--text-faded);
            font-weight: 600;
        }

    .cta-panel {
        position: relative;
        padding: 3rem 2rem;
        border-radius: 32px;
        overflow: hidden;
    }

        .cta-panel::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top left, rgba(97, 218, 251, 0.14), transparent 30%), radial-gradient(circle at bottom right, rgba(124, 77, 255, 0.14), transparent 30%);
            pointer-events: none;
        }

        .cta-panel h2 {
            font-size: clamp(2rem, 5vw, 3.4rem);
            font-weight: 900;
            margin-bottom: 1rem;
        }

        .cta-panel p {
            color: var(--text-soft);
            font-size: 1.05rem;
            line-height: 1.9;
            max-width: 760px;
            margin: 0 auto 1.8rem;
        }

    .scroll-indicator {
        position: absolute;
        left: 50%;
        bottom: 1.2rem;
        transform: translateX(-50%);
        color: var(--text-faded);
        font-size: .9rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .45rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        animation: bounceDown 2.4s infinite;
    }

        .scroll-indicator i {
            color: var(--accent);
            font-size: 1.1rem;
        }

    .reveal {
        opacity: 0;
        transform: translateY(36px);
        transition: opacity .8s ease, transform .8s ease;
    }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

    @@keyframes gridShift {
        0% {
            transform: translateY(0);
        }

        100% {
            transform: translateY(42px);
        }
    }

    @@keyframes floatOrb1 {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(80px, 50px) scale(1.12);
        }
    }

    @@keyframes floatOrb2 {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(-70px, 60px) scale(1.08);
        }
    }

    @@keyframes floatOrb3 {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(50px, -65px) scale(1.1);
        }
    }

    @@keyframes rise {
        0% {
            transform: translateY(0) translateX(0);
            opacity: 0;
        }

        10% {
            opacity: .95;
        }

        70% {
            opacity: .65;
        }

        100% {
            transform: translateY(-110vh) translateX(25px);
            opacity: 0;
        }
    }

    @@keyframes pulseSoft {
        0%, 100% {
            transform: scale(1);
            box-shadow: 0 0 0 rgba(97, 218, 251, 0.0);
        }

        50% {
            transform: scale(1.03);
            box-shadow: 0 0 20px rgba(97, 218, 251, 0.08);
        }
    }

    @@keyframes spinSlow {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    @@keyframes hoverCore {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-12px);
        }
    }

    @@keyframes floatCard {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    @@keyframes bounceDown {
        0%, 100% {
            transform: translateX(-50%) translateY(0);
            opacity: .8;
        }

        50% {
            transform: translateX(-50%) translateY(8px);
            opacity: 1;
        }
    }

    @@media (max-width: 991.98px) {
        .hero-section {
            min-height: auto;
            padding-top: 3rem;
        }

        .hero-visual {
            min-height: 460px;
            margin-top: 2rem;
        }

        .chip-a, .chip-b, .chip-c, .chip-d {
            min-width: 130px;
            padding: .7rem .85rem;
        }

        .ring-1 {
            width: 320px;
            height: 320px;
        }

        .ring-2 {
            width: 250px;
            height: 250px;
        }

        .ring-3 {
            width: 180px;
            height: 180px;
        }

        .cpu-core {
            width: 180px;
            height: 180px;
        }
    }

    @@media (max-width: 767.98px) {
        .hero-title {
            font-size: 2.6rem;
        }

        .hero-subtitle {
            font-size: 1rem;
        }

        .hero-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-main-glow,
        .btn-outline-glow {
            width: 100%;
            text-align: center;
        }

        .hero-visual {
            min-height: 390px;
        }

        .floating-chip {
            min-width: auto;
            width: 140px;
        }

        .scroll-indicator {
            display: none;
        }
    }
</style>

<div class="pcj-home-wrapper">

    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>
    <div class="bg-orb orb-3"></div>

    <div class="particles">
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
        <span class="particle"></span>
    </div>

    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-7">
                    <div class="hero-badge reveal">
                        <i class="fa-solid fa-bolt"></i>
                        Build harder. Browse faster. Waste no time.
                    </div>

                    <h1 class="hero-title reveal">
                        The <span class="title-glow">no BS</span><br />
                        PC building hub.
                    </h1>

                    <p class="hero-subtitle reveal">
                        <strong class="text-white">PC Junkie</strong> is made for people who want parts, builds,
                        prices, and clean choices without the usual clutter. Browse components, compare hardware,
                        create your own rig, and send tickets when you need real help. Fast look. Sharp UI. Straight to the point.
                    </p>

                    <div class="hero-actions reveal">
                        <a asp-controller="Browse"
                           asp-action="Index"
                           asp-route-partType="CPU"
                           class="btn btn-main-glow">
                            <i class="fa-solid fa-microchip me-2"></i>
                            Browse Parts Now
                        </a>

                        <a asp-controller="Builds"
                           asp-action="Index"
                           class="btn btn-outline-glow">
                            <i class="fa-solid fa-screwdriver-wrench me-2"></i>
                            Explore Builds
                        </a>

                        <a asp-controller="Contacts"
                           asp-action="Index"
                           class="btn btn-outline-glow">
                            <i class="fa-solid fa-headset me-2"></i>
                            Contact Support
                        </a>
                    </div>

                    <div class="hero-mini-note reveal">
                        <i class="fa-solid fa-circle-info me-1 text-info"></i>
                        Pick a part category, start a build, or send a ticket to admin without leaving the site.
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="hero-visual reveal">
                        <div class="core-ring ring-1"></div>
                        <div class="core-ring ring-2"></div>
                        <div class="core-ring ring-3"></div>

                        <div class="floating-chip chip-a">
                            <strong><i class="fa-solid fa-microchip me-2 text-info"></i> CPUs</strong>
                            <span>Socket, cores, clocks</span>
                        </div>

                        <div class="floating-chip chip-b">
                            <strong><i class="fa-solid fa-tv me-2 text-info"></i> GPUs</strong>
                            <span>VRAM, chipset, power</span>
                        </div>

                        <div class="floating-chip chip-c">
                            <strong><i class="fa-solid fa-memory me-2 text-info"></i> RAM</strong>
                            <span>Speed, type, capacity</span>
                        </div>

                        <div class="floating-chip chip-d">
                            <strong><i class="fa-solid fa-hard-drive me-2 text-info"></i> Storage</strong>
                            <span>Fast picks, clear specs</span>
                        </div>

                        <div class="cpu-core">
                            <div class="cpu-inner">
                                <i class="fa-solid fa-desktop"></i>
                                <h2>PC Junkie</h2>
                                <p>Build the machine you actually want.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

